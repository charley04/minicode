{
  "name": "minicode-agent",
  "version": "1.0.0",
  "description": "A lightweight AI coding agent for the terminal — multi-provider, MCP, skills, code review",
  "type": "module",
  "bin": {
    "minicode": "./dist/index.js"
  },
  "files": [
    "dist/**/*",
    "README.md"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "tsc"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "ai",
    "agent",
    "cli",
    "coding-assistant",
    "llm",
    "mcp",
    "opencode"
  ],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "@google/generative-ai": "^0.24.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.4.1",
    "cli-highlight": "^2.1.11",
    "commander": "^12.1.0",
    "glob": "^11.0.1",
    "marked": "^18.0.6",
    "openai": "^4.77.3",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
